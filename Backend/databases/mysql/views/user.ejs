<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>All User</title>
    <style>
        table,th,td{
            border: 1px solid black;
        }
    </style>
</head>
<body>
    <a href="http://localhost:3000/user/new">ADD NEW USER</a>
    <table>
        <tr>
            <th>
                ID
            </th>
            <th>
                Username
            </th>
            <th>
                Email
            </th>
        </tr>
        <% for(user of users){ %>
        <tr>
            <td><%= user.userid %></td>
            <td><%= user.username %></td>
            <td><%= user.email %></td>
            <td>
                <form method="GET" action="/user/<%= user.userid %>/edit">
                    <button>edit</button>
                </form>
                
            <td>
            <td>
                <form method="get" action="/user/<%= user.userid %>/delete">
                    <button>Delete</button>
                </form>
                
            <td>
        </tr>
       <% } %>
    </table>
</body>
</html>

