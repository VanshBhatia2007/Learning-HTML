<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit Username</title>
</head>
<body>
    <h1>Edit your username : <%= user.email %></h1>
    <form action="/user/<%= user.userid %>?_method=PATCH"  method="POST">
        <textarea name="username"><%= user.username %></textarea> <br>
        <input type="password" name="password" placeholder="enter your password"><br>
        <button>edit</button>
    </form>
</body>
</html>